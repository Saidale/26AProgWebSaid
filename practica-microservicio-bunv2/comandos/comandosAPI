curl -Method PUT -Uri "http://localhost:3000/aula/1" -Headers @{"Content-Type"="application/json"} -Body '{"numero_aula": 12, "piso_edificio": "PISO 1 EDIFICIO 1", "capacidad_maxima": 40, "tipo_aula": "TALLER"}' | Select-Object -ExpandProperty Content


#---------------------------USUARIOS----------------------------------------------------------
# GET - Consultar todos los usuarios
curl -Method GET -Uri "http://localhost:3000/usuarios" | Select-Object -ExpandProperty Content

# POST - Crear un nuevo usuario
curl -Method POST -Uri "http://localhost:3000/usuarios" -Headers @{"Content-Type"="application/json"} -Body '{"nombre": "Luis", "email": "luis@test.com"}' | Select-Object -ExpandProperty Content

# GET por ID - Consultar el usuario creado (ejemplo con ID 1)
curl -Method GET -Uri "http://localhost:3000/usuarios/1" | Select-Object -ExpandProperty Content

# PUT - Actualizar el usuario (ejemplo con ID 1)
curl -Method PUT -Uri "http://localhost:3000/usuarios/1" -Headers @{"Content-Type"="application/json"} -Body '{"nombre": "Luis Editado", "email": "luis_nuevo@test.com"}' | Select-Object -ExpandProperty Content

# DELETE - Eliminar el usuario (ejemplo con ID 1)
curl -Method DELETE -Uri "http://localhost:3000/usuarios/1"

#------------------------------PROFESORES-------------------------------------------

